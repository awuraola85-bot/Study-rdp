name: Cloud Auto-Recovery
on:
  schedule:
    - cron: '*/10 * * * *'
  workflow_dispatch:

jobs:
  health-check:
    runs-on: ubuntu-latest
    steps:
      - name: Check & Recover Cloud Servers
        run: |
          # Check for running instances
          RUNNING=$(curl -s -H "Authorization: token ${{ secrets.GH_PAT }}" \
            -H "Accept: application/vnd.github.v3+json" \
            "https://api.github.com/repos/${{ github.repository }}/actions/runs?status=in_progress&per_page=100" | \
            python3 -c "import sys,json; runs=json.load(sys.stdin)['workflow_runs']; print(len([r for r in runs if 'Cloud' in r.get('name','')])))"
          
          echo "Running cloud instances: $RUNNING"
          
          if [ "$RUNNING" -lt "1" ]; then
            echo "⚠ No cloud servers running! Triggering deployment..."
            curl -X POST \
              -H "Authorization: token ${{ secrets.GH_PAT }}" \
              -H "Accept: application/vnd.github.v3+json" \
              "https://api.github.com/repos/${{ github.repository }}/actions/workflows/cloud-controller.yml/dispatches" \
              -d '{"ref":"main","inputs":{"windows_server":"true","linux_server":"true"}}'
            echo "✓ Recovery deployment triggered"
          else
            echo "✓ Cloud servers are running ($RUNNING instances)"
          fi
